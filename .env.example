# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_ENV=development

# LLM API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# AWS Configuration (credentials via env vars, IAM role, or ~/.aws/credentials)
AWS_REGION=us-east-1

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_RESUME_PARSED=resume.parsed
KAFKA_TOPIC_ATS_OPTIMIZED=resume.ats_optimized
KAFKA_TOPIC_SUGGESTIONS=resume.suggestions
KAFKA_TOPIC_INTERVIEWS=interview.questions

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=resume-optimizer
OTEL_EXPORTER_PROMETHEUS_PORT=8001

# Agent Configuration
MAX_RETRIES=3
TIMEOUT_SECONDS=30
